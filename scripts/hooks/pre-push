#!/bin/sh
# push 전 Next.js 프로덕션 빌드로 검증합니다. 실패 시 exit 1 → push 취소.
# 긴급히 훅을 건너뛰려면: git push --no-verify

set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if ! command -v pnpm >/dev/null 2>&1; then
  printf '\n❌ pre-push: pnpm이 없습니다. corepack enable 후 다시 시도하세요.\n\n' >&2
  exit 1
fi

printf '\n🔨 pre-push: pnpm run build 실행 중...\n\n'

pnpm run build

printf '\n✅ pre-push: 빌드 성공. push를 진행합니다.\n\n'
