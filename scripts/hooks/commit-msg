#!/usr/bin/env bash
COMMIT_MSG_FILE=$1

# Cursor 에이전트가 붙이는 Co-authored-by 제거 (GitHub 이중 작성자 표시 방지)
if [[ -n "${COMMIT_MSG_FILE:-}" && -f "$COMMIT_MSG_FILE" ]]; then
  tmp_strip=$(mktemp)
  grep -Ev '^[Cc]o-[Aa]uthored-by:[[:space:]]*[Cc]ursor[[:space:]]*<' "$COMMIT_MSG_FILE" >"$tmp_strip" || true
  mv "$tmp_strip" "$COMMIT_MSG_FILE"
fi

# 주석·빈 줄을 건너뛰고 첫 “실제” 줄을 제목으로 본다
get_title_line() {
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// }" ]] && continue
    echo "$line"
    return 0
  done <"$COMMIT_MSG_FILE"
  return 1
}

if ! TITLE_LINE=$(get_title_line); then
  echo "❌ 커밋 메시지가 비어 있습니다."
  exit 1
fi

# 이미 "| id | HH:MM" 형태가 붙어 있으면 Author 처리 생략
if ! echo "$TITLE_LINE" | grep -qE ' \| [^|]+ \| [0-9]{2}:[0-9]{2}$'; then
  REMOTE_URL=$(git config --get remote.origin.url 2>/dev/null)
  if [[ "$REMOTE_URL" =~ github\.com[:/]([^/]+)/ ]]; then
    GITHUB_ID="${BASH_REMATCH[1]}"
  else
    USER_EMAIL=$(git config user.email 2>/dev/null)
    if [[ "$USER_EMAIL" =~ ^([^+@]+)(\+[^@]+)?@users\.noreply\.github.com$ ]]; then
      GITHUB_ID="${BASH_REMATCH[1]}"
    else
      GITHUB_ID=$(git config user.name)
    fi
  fi
  COMMIT_TIME=$(date +"%H:%M")
  NEW_FIRST="${TITLE_LINE} | ${GITHUB_ID} | ${COMMIT_TIME}"

  # 파일 첫 “실제” 줄만 교체 (앞선 주석·빈 줄 유지)
  tmp=$(mktemp)
  replaced=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ $replaced -eq 0 ]] && [[ ! "$line" =~ ^[[:space:]]*# ]] && [[ -n "${line// }" ]]; then
      echo "$NEW_FIRST" >>"$tmp"
      replaced=1
      continue
    fi
    echo "$line" >>"$tmp"
  done <"$COMMIT_MSG_FILE"
  mv "$tmp" "$COMMIT_MSG_FILE"
fi

FIRST_LINE=$(get_title_line)
CORE=$(echo "$FIRST_LINE" | sed -E 's/ \| [^|]+ \| [0-9]{2}:[0-9]{2}$//')
PATTERN="^(feat|fix|docs|style|refactor|test|chore|perf|hotfix)(\(.+\))?: .{1,50}$"

if ! echo "$CORE" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌ 커밋 메시지 형식 오류!"
  echo ""
  echo "올바른 형식: <type>(<scope>): <subject>"
  echo "(subject 50자 이내, scope 생략 가능. 예: docs: README 수정)"
  echo ""
  echo "사용 가능한 타입: feat | fix | docs | style | refactor | test | chore | perf | hotfix"
  echo ""
  exit 1
fi

exit 0
